<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="wrap">
    <div>
      <%- include('partials/brand') %>
      <div class="card">
        <h1>Two-factor verification</h1>
        <p class="subtitle">Enter the 6-digit code from your authenticator app, or one of your backup codes.</p>

        <%- include('partials/flash') %>

        <form method="POST" action="/login/2fa">
          <div class="field">
            <label for="code">Authentication code</label>
            <input type="text" id="code" name="code" placeholder="123456" autocomplete="one-time-code" inputmode="numeric" required autofocus>
            <p class="hint">Backup codes look like <code>3f9a-2b7c1d</code> — those work here too.</p>
          </div>
          <button class="btn btn-primary" type="submit">Verify</button>
        </form>

        <hr class="divider">
        <div class="foot-links">
          <a href="/login">Back to log in</a>
        </div>
      </div>
    </div>
    <%- include('partials/footer') %>
  </div>
</body>
</html>
